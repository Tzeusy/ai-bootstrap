#!/usr/bin/env bash
# Bootstrap a full __APP_NAME__ dev environment in tmux.
#
# Layout (__WINDOW_NAME__):
#   __LAYOUT_DIAGRAM__
#
# Startup Layers:
#   Layer 0 - optional reverse-proxy preflight (tailscale serve)
#   Layer 1 - launch panes/services
#   Layer 2 - readiness gates + URL output
#
# Usage: ./dev.sh [--skip-tailscale-check]

set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WINDOW="__WINDOW_NAME__"

SKIP_TAILSCALE_CHECK=false
for arg in "$@"; do
  case "$arg" in
    --skip-tailscale-check) SKIP_TAILSCALE_CHECK=true ;;
    *)
      echo "Error: unknown argument: $arg" >&2
      echo "Usage: ./dev.sh [--skip-tailscale-check]" >&2
      exit 1
      ;;
  esac
done

normalize_path_prefix() {
  local p="${1:-/}"
  if [ -z "$p" ]; then
    p="/"
  fi
  if [ "${p#/}" = "$p" ]; then
    p="/${p}"
  fi
  if [ "$p" != "/" ]; then
    p="${p%/}"
  fi
  echo "$p"
}

path_prefix_to_base() {
  local p="$1"
  if [ "$p" = "/" ]; then
    echo "/"
  else
    echo "${p}/"
  fi
}

get_serve_target_ports_for_path() {
  local target="$1"
  local path_prefix="$2"
  local status_json="$3"
  SERVE_STATUS_JSON="$status_json" python3 - "$target" "$path_prefix" <<'PY'
import json
import os
import sys

target = sys.argv[1]
path_prefix = sys.argv[2]
data = json.loads(os.environ.get("SERVE_STATUS_JSON", "{}"))
ports = set()

for hostport, cfg in (data.get("Web") or {}).items():
    handlers = (cfg or {}).get("Handlers") or {}
    for handler_path, handler in handlers.items():
        if (
            handler_path == path_prefix
            and isinstance(handler, dict)
            and handler.get("Proxy") == target
        ):
            try:
                _, port_str = hostport.rsplit(":", 1)
                port = int(port_str)
            except Exception:
                port = 443
            ports.add(str(port))
            break

if not ports:
    raise SystemExit(1)

print(" ".join(sorted(ports, key=int)))
PY
}

port_present_in_list() {
  local ports="$1"
  local wanted="$2"
  local p
  for p in $ports; do
    if [ "$p" = "$wanted" ]; then
      return 0
    fi
  done
  return 1
}

resolve_tailscale_dashboard_url() {
  local ts_hostname=""
  ts_hostname=$(
    tailscale status --json 2>/dev/null | \
      python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('Self',{}).get('DNSName','').rstrip('.'))" 2>/dev/null || \
      echo ""
  )
  if [ -z "$ts_hostname" ]; then
    return 1
  fi

  if [ "$TAILSCALE_HTTPS_PORT" = "443" ]; then
    if [ "$TAILSCALE_PATH_PREFIX" = "/" ]; then
      TAILSCALE_DASHBOARD_URL="https://${ts_hostname}/"
    else
      TAILSCALE_DASHBOARD_URL="https://${ts_hostname}${TAILSCALE_PATH_PREFIX}/"
    fi
  else
    if [ "$TAILSCALE_PATH_PREFIX" = "/" ]; then
      TAILSCALE_DASHBOARD_URL="https://${ts_hostname}:${TAILSCALE_HTTPS_PORT}/"
    else
      TAILSCALE_DASHBOARD_URL="https://${ts_hostname}:${TAILSCALE_HTTPS_PORT}${TAILSCALE_PATH_PREFIX}/"
    fi
  fi
  return 0
}

run_serve_mapping() {
  local path_prefix="$1"
  local target="$2"
  local cmd_output=""
  local rc=0

  if [ "$path_prefix" = "/" ]; then
    cmd_output=$(tailscale serve --yes --bg --https="${TAILSCALE_HTTPS_PORT}" "$target" 2>&1) || rc=$?
  else
    cmd_output=$(tailscale serve --yes --bg --https="${TAILSCALE_HTTPS_PORT}" --set-path "$path_prefix" "$target" 2>&1) || rc=$?
  fi

  if [ "$rc" -ne 0 ] && echo "$cmd_output" | grep -Eqi "(invalid argument format|unknown flag|usage)"; then
    rc=0
    if [ "$path_prefix" = "/" ]; then
      cmd_output=$(tailscale serve "https:${TAILSCALE_HTTPS_PORT}" "$target" 2>&1) || rc=$?
    else
      cmd_output=$(tailscale serve "https:${TAILSCALE_HTTPS_PORT}" "$path_prefix" "$target" 2>&1) || rc=$?
    fi
  fi

  echo "$cmd_output"
  return "$rc"
}

ensure_tailscale_serve() {
  if ! command -v tailscale &>/dev/null; then
    echo "Error: tailscale CLI not found on PATH" >&2
    echo "Install: https://tailscale.com/download" >&2
    echo "Or skip this check: ./dev.sh --skip-tailscale-check" >&2
    return 1
  fi

  local ts_status="{}"
  ts_status=$(tailscale status --json 2>/dev/null) || true
  local ts_state
  ts_state=$(
    echo "$ts_status" | \
      python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('BackendState','Unknown'))" 2>/dev/null || \
      echo "Unknown"
  )
  if [ "$ts_state" = "NeedsLogin" ] || [ "$ts_state" = "NoState" ] || [ "$ts_state" = "Stopped" ]; then
    echo "Error: tailscale is not authenticated (state: ${ts_state})" >&2
    echo "Run: tailscale up" >&2
    echo "Or skip this check: ./dev.sh --skip-tailscale-check" >&2
    return 1
  fi

  local serve_status_json="{}"
  serve_status_json=$(tailscale serve status --json 2>/dev/null) || serve_status_json="{}"
  local existing_ports=""
  existing_ports=$(
    get_serve_target_ports_for_path "$TAILSCALE_TARGET" "$TAILSCALE_PATH_PREFIX" "$serve_status_json" 2>/dev/null || true
  )

  if port_present_in_list "$existing_ports" "$TAILSCALE_HTTPS_PORT"; then
    resolve_tailscale_dashboard_url || true
    echo "Layer 0: tailscale serve already configured (${TAILSCALE_PATH_PREFIX} -> ${TAILSCALE_TARGET})"
    return 0
  fi

  local start_output=""
  if ! start_output=$(run_serve_mapping "$TAILSCALE_PATH_PREFIX" "$TAILSCALE_TARGET"); then
    echo "Error: failed to configure tailscale serve" >&2
    echo "Required mapping: ${TAILSCALE_PATH_PREFIX} -> ${TAILSCALE_TARGET}" >&2
    if [ -n "$start_output" ]; then
      echo "tailscale output:" >&2
      echo "$start_output" >&2
    fi
    if echo "$start_output" | grep -qi "Access denied: serve config denied"; then
      echo "Permission hint: sudo tailscale set --operator=$USER" >&2
    fi
    return 1
  fi

  serve_status_json=$(tailscale serve status --json 2>/dev/null) || serve_status_json="{}"
  existing_ports=$(
    get_serve_target_ports_for_path "$TAILSCALE_TARGET" "$TAILSCALE_PATH_PREFIX" "$serve_status_json" 2>/dev/null || true
  )
  if ! port_present_in_list "$existing_ports" "$TAILSCALE_HTTPS_PORT"; then
    echo "Error: tailscale mapping not observed after apply (check: tailscale serve status)" >&2
    return 1
  fi

  resolve_tailscale_dashboard_url || true
  echo "Layer 0: tailscale serve ready (${TAILSCALE_PATH_PREFIX} -> ${TAILSCALE_TARGET})"
}

wait_for_port() {
  local port="$1"
  local name="${2:-port $1}"
  local retries="${3:-30}"
  local i
  echo "Waiting for ${name}..."
  for i in $(seq 1 "$retries"); do
    if nc -z localhost "$port" 2>/dev/null; then
      echo "${name} ready"
      return 0
    fi
    sleep 1
  done
  echo "Timed out waiting for ${name}" >&2
  return 1
}

wait_for_http() {
  local url="$1"
  local label="$2"
  local max_wait="${3:-60}"
  local interval=2
  local elapsed=0
  echo "Waiting for ${label} (${url})..."
  while [ "$elapsed" -lt "$max_wait" ]; do
    if curl -sf "$url" >/dev/null 2>&1; then
      echo "${label} ready (${elapsed}s)"
      return 0
    fi
    sleep "$interval"
    elapsed=$((elapsed + interval))
  done
  echo "Warning: ${label} not ready within ${max_wait}s" >&2
  return 1
}

# Optional reverse-proxy knobs.
# If your app does not use path-prefix routing, set TAILSCALE_PATH_PREFIX=/.
FRONTEND_PORT="${FRONTEND_PORT:-5173}"
BACKEND_PORT="${BACKEND_PORT:-9990}"
TAILSCALE_HTTPS_PORT="${TAILSCALE_HTTPS_PORT:-443}"
TAILSCALE_PATH_PREFIX_RAW="${TAILSCALE_PATH_PREFIX:-/__APP_SLUG__}"
TAILSCALE_PATH_PREFIX="$(normalize_path_prefix "$TAILSCALE_PATH_PREFIX_RAW")"
FRONTEND_BASE_PATH="$(path_prefix_to_base "$TAILSCALE_PATH_PREFIX")"
if [ "$TAILSCALE_PATH_PREFIX" = "/" ]; then
  TAILSCALE_TARGET="http://localhost:${FRONTEND_PORT}"
else
  # Preserve prefix routing end-to-end through the local dev server.
  TAILSCALE_TARGET="http://localhost:${FRONTEND_PORT}${TAILSCALE_PATH_PREFIX}"
fi

LOCAL_FRONTEND_URL="http://localhost:${FRONTEND_PORT}${FRONTEND_BASE_PATH}"
LOCAL_BACKEND_API_BASE_URL="http://localhost:${BACKEND_PORT}/api"
TAILSCALE_DASHBOARD_URL=""

# --- Prerequisites -----------------------------------------------------------
if ! command -v tmux &>/dev/null; then
  echo "Error: tmux is not installed" >&2
  exit 1
fi

# --- Layer 0: optional tailscale preflight ----------------------------------
if [ "$SKIP_TAILSCALE_CHECK" = "false" ]; then
  ensure_tailscale_serve
else
  echo "Layer 0: skipping tailscale preflight (--skip-tailscale-check)"
fi

# --- Session handling --------------------------------------------------------
if [ -n "${TMUX:-}" ]; then
  SESSION="$(tmux display-message -p '#S')"
else
  SESSION="__SESSION_NAME__"
  tmux new-session -d -s "$SESSION" -c "$PROJECT_DIR" 2>/dev/null || true
fi

# --- Idempotent: tear down previous run --------------------------------------
tmux kill-window -t "${SESSION}:${WINDOW}" 2>/dev/null || true

# --- Create window + panes (capture pane IDs; never use indices) -------------
PANE_0=$(tmux new-window -t "$SESSION" -n "$WINDOW" -c "$PROJECT_DIR" -P -F '#{pane_id}')
# PANE_1=$(tmux split-window -t "$PANE_0" -h -c "$PROJECT_DIR" -P -F '#{pane_id}')
# PANE_2=$(tmux split-window -t "$PANE_1" -v -c "$PROJECT_DIR" -P -F '#{pane_id}')
# PANE_3=$(tmux split-window -t "$PANE_0" -v -c "$PROJECT_DIR" -P -F '#{pane_id}')

# Avoid occasional dropped keystrokes on fast reruns.
sleep 0.3

# --- Per-run logs ------------------------------------------------------------
LOGS_ROOT="${PROJECT_DIR}/logs"
LOGS_RUN_ID="$(date +%Y%m%d_%H%M%S)"
LOGS_RUN_DIR="${LOGS_ROOT}/${LOGS_RUN_ID}"
LOGS_LATEST_LINK="${LOGS_ROOT}/latest"

mkdir -p "${LOGS_RUN_DIR}"
rm -rf "${LOGS_LATEST_LINK}"
ln -s "${LOGS_RUN_DIR}" "${LOGS_LATEST_LINK}"
echo "Logs for this run: ${LOGS_RUN_DIR}"

pipe_pane_to_log() {
  local pane_id="$1"
  local log_file="$2"
  tmux pipe-pane -o -t "$pane_id" \
    "perl -pe 'BEGIN { \$| = 1 } s/\\e\\[[0-?]*[ -\\/]*[@-~]//g; s/\\e\\][^\\a]*(?:\\a|\\e\\\\)//g; s/\\r//g; s/[\\x00-\\x08\\x0B\\x0C\\x0E-\\x1F\\x7F]//g' >> '${log_file}'"
}

pipe_pane_to_log "$PANE_0" "${LOGS_RUN_DIR}/pane-0.log"
# pipe_pane_to_log "$PANE_1" "${LOGS_RUN_DIR}/pane-1.log"
# pipe_pane_to_log "$PANE_2" "${LOGS_RUN_DIR}/pane-2.log"
# pipe_pane_to_log "$PANE_3" "${LOGS_RUN_DIR}/pane-3.log"

# --- Environment -------------------------------------------------------------
ENV_CMD=""
if [ -f "${PROJECT_DIR}/.env" ]; then
  ENV_CMD="set -a; source ${PROJECT_DIR}/.env; set +a; "
fi

# --- Layer 1: launch services ------------------------------------------------
# Prefix-coherency note:
# If you use TAILSCALE_PATH_PREFIX != "/", ensure frontend/router/API/proxy
# are base-path aware and pass --base (or framework equivalent) as needed.

# Pane 0: __SERVICE_0__
tmux send-keys -t "$PANE_0" "__CMD_0__" Enter

# Pane 1: __SERVICE_1__
# tmux send-keys -t "$PANE_1" "__CMD_1__" Enter

# Pane 2: __SERVICE_2__
# tmux send-keys -t "$PANE_2" "__CMD_2__" Enter

# Pane 3: __SERVICE_3__
# tmux send-keys -t "$PANE_3" "__CMD_3__" Enter

# Example frontend command with base-path wiring:
# tmux send-keys -t "$PANE_1" \
#   "npm install && FRONTEND_BASE_PATH=${FRONTEND_BASE_PATH} VITE_API_PROXY_TARGET=http://127.0.0.1:${BACKEND_PORT} npm run dev -- --host 0.0.0.0 --port ${FRONTEND_PORT} --strictPort --base ${FRONTEND_BASE_PATH}" \
#   Enter

# --- Layer 2: readiness gates ------------------------------------------------
# Uncomment/adapt for your app:
# wait_for_port 5432 postgres 45 || true
# wait_for_http "http://localhost:${BACKEND_PORT}/ready" "backend readiness" 60 || true
# wait_for_http "${LOCAL_FRONTEND_URL}" "frontend root" 60 || true

echo "Local frontend URL: ${LOCAL_FRONTEND_URL}"
echo "Local backend API base URL: ${LOCAL_BACKEND_API_BASE_URL}"
if [ -n "$TAILSCALE_DASHBOARD_URL" ]; then
  echo "Tailscale frontend URL: ${TAILSCALE_DASHBOARD_URL}"
fi

# --- Layout + focus ----------------------------------------------------------
tmux select-layout -t "${SESSION}:${WINDOW}" __TMUX_LAYOUT__
tmux select-pane -t "$PANE_0"

# --- Attach if we started detached ------------------------------------------
if [ -z "${TMUX:-}" ]; then
  exec tmux attach-session -t "$SESSION"
fi
